# Application
APP_NAME="OpenOrch Backend"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=true

# Server
HOST="0.0.0.0"
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Security
SECRET_KEY="your-secret-key-here-change-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_V1_PREFIX="/api/v1"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/openorch"
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
RABBITMQ_TEST_RUNS_QUEUE="test_runs"

# Internal service auth
INTERNAL_SERVICE_SECRET="your-internal-secret-here-change-in-production"

# Consumer service
BE_BASE_URL="http://localhost:8000"

# Browser (Playwright) — set BROWSER_HEADLESS=false to watch the browser locally
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
# BROWSER_HEADLESS=true
# BROWSER_SLOW_MO=0

# Storage ("local" for dev, "s3" for production)
STORAGE_BACKEND="local"
LOCAL_RECORDINGS_DIR="./recordings"
# S3_BUCKET="your-bucket-name"
# S3_REGION="us-east-1"
