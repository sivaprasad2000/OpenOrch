# -----------------------------------------------
# API (apps/api)
# -----------------------------------------------
APP_NAME="OpenOrch"
ENVIRONMENT="development"
DEBUG=true

HOST="0.0.0.0"
PORT=8000

SECRET_KEY="change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30
INTERNAL_SERVICE_SECRET="change-me-in-production"

API_V1_PREFIX="/api/v1"
CORS_ORIGINS=["http://localhost:3000"]

DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/openorch"
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
RABBITMQ_TEST_RUNS_QUEUE="test_runs"

BE_BASE_URL="http://localhost:8000"

STORAGE_BACKEND="local"
LOCAL_RECORDINGS_DIR="./recordings"
# S3_BUCKET=
# S3_REGION=

BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
# BROWSER_HEADLESS=true
# BROWSER_SLOW_MO=0

# -----------------------------------------------
# Web (apps/web)
# -----------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth (Phase 2)
# NEXT_PUBLIC_AUTH_PROVIDER=
# AUTH_SECRET=
# AUTH_CLIENT_ID=
# AUTH_CLIENT_SECRET=
